# ── Domain ───────────────────────────────────────────────────────────────────────
# GXP_DOMAIN controls every subdomain used by Traefik, Keycloak, and the frontend.
#
# Local dev (browser on the same machine):
#   GXP_DOMAIN=gxp.localhost
#   Add to /etc/hosts:
#     127.0.0.1  portal.gxp.localhost api.gxp.localhost keycloak.gxp.localhost
#     127.0.0.1  runtime.gxp.localhost minio.gxp.localhost
#
# Test server (browser on a different machine, no public DNS):
#   Use nip.io — replace SERVER_IP with the test server's actual IP address.
#   GXP_DOMAIN=<SERVER_IP>.nip.io  e.g. GXP_DOMAIN=192-168-1-100.nip.io
#   No /etc/hosts changes needed — nip.io resolves all subdomains to the embedded IP.
#
# Production:
#   GXP_DOMAIN=gxp.agency.gov
#   Requires a wildcard DNS record: *.gxp.agency.gov → server IP
GXP_DOMAIN=gxp.localhost

# ── TLS Certificates ─────────────────────────────────────────────────────────────
# All external traffic is served over HTTPS. Certificates live in infra/docker/certs/.
#
# Self-signed (default — run once before docker compose up):
#   infra/scripts/gen-certs.sh
#   This generates infra/docker/certs/tls.crt and tls.key for *.GXP_DOMAIN.
#   Import tls.crt into your browser/OS trust store to remove the "Not secure" warning.
#
# CA-signed certificate (production / no browser warning):
#   Place your certificate at infra/docker/certs/tls.crt
#   Place your private key  at infra/docker/certs/tls.key
#   Then restart Traefik:   docker compose restart traefik
#
# Internal service-to-service calls (Docker network) remain plain HTTP.

# ── PostgreSQL ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=changeme_dev

# ── Keycloak ────────────────────────────────────────────────────────────────────
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=changeme_dev

# ── MinIO ───────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_dev

# ── Valkey (Redis) ──────────────────────────────────────────────────────────────
VALKEY_PASSWORD=changeme_dev

# ── Service secrets (OAuth2 client credentials) ─────────────────────────────────
TENANT_SERVICE_CLIENT_SECRET=changeme_dev
APP_SERVICE_CLIENT_SECRET=changeme_dev
WORKFLOW_SERVICE_CLIENT_SECRET=changeme_dev
CASE_SERVICE_CLIENT_SECRET=changeme_dev
DOCUMENT_SERVICE_CLIENT_SECRET=changeme_dev
AUDIT_SERVICE_CLIENT_SECRET=changeme_dev
NOTIFICATION_SERVICE_CLIENT_SECRET=changeme_dev
