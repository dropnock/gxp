{
  "realm": "gxp-{tenant_slug}",
  "displayName": "{tenant_name}",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "permanentLockout": false,
  "maxFailureWaitSeconds": 900,
  "minimumQuickLoginWaitSeconds": 60,
  "waitIncrementSeconds": 60,
  "quickLoginCheckMilliSeconds": 1000,
  "maxDeltaTimeSeconds": 43200,
  "failureFactor": 5,
  "accessTokenLifespan": 900,
  "refreshTokenMaxReuse": 0,
  "revokeRefreshToken": true,

  "roles": {
    "realm": [
      { "name": "gxp-admin",        "description": "Tenant administrator" },
      { "name": "gxp-developer",    "description": "Can build apps and create workflows" },
      { "name": "gxp-approver",     "description": "Can review and publish apps/workflows" },
      { "name": "gxp-user",         "description": "End-user of published apps" },
      { "name": "gxp-auditor",      "description": "Read-only access to audit logs" },
      { "name": "gxp-case-worker",  "description": "Creates and manages cases" },
      { "name": "gxp-case-manager", "description": "Manages case types and assignments" }
    ]
  },

  "clients": [
    {
      "clientId": "gxp-portal",
      "name": "GXP Developer Portal",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "pkceCodeChallengeMethod": "S256",
      "redirectUris": [
        "https://portal.{gxp_domain}/*",
        "https://{tenant_slug}.portal.{gxp_domain}/*",
        "http://localhost:5173/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": ["+"]
    },
    {
      "clientId": "gxp-runtime",
      "name": "GXP App Runtime",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "pkceCodeChallengeMethod": "S256",
      "redirectUris": [
        "https://runtime.{gxp_domain}/*",
        "https://{tenant_slug}.apps.{gxp_domain}/*"
      ],
      "webOrigins": ["+"]
    },
    { "clientId": "gxp-app-service",          "enabled": true, "publicClient": false, "serviceAccountsEnabled": true, "standardFlowEnabled": false },
    { "clientId": "gxp-workflow-service",      "enabled": true, "publicClient": false, "serviceAccountsEnabled": true, "standardFlowEnabled": false },
    { "clientId": "gxp-case-service",          "enabled": true, "publicClient": false, "serviceAccountsEnabled": true, "standardFlowEnabled": false },
    { "clientId": "gxp-document-service",      "enabled": true, "publicClient": false, "serviceAccountsEnabled": true, "standardFlowEnabled": false },
    { "clientId": "gxp-audit-service",         "enabled": true, "publicClient": false, "serviceAccountsEnabled": true, "standardFlowEnabled": false },
    { "clientId": "gxp-notification-service",  "enabled": true, "publicClient": false, "serviceAccountsEnabled": true, "standardFlowEnabled": false }
  ],

  "authenticationFlows": [
    {
      "alias": "gxp-browser-mfa",
      "description": "GXP browser flow with mandatory TOTP MFA",
      "providerId": "basic-flow",
      "topLevel": true,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-cookie",                 "requirement": "ALTERNATIVE", "priority": 10 },
        { "authenticator": "identity-provider-redirector","requirement": "ALTERNATIVE", "priority": 25 },
        { "flowAlias": "gxp-forms",                       "requirement": "ALTERNATIVE", "priority": 30, "autheticatorFlow": true }
      ]
    },
    {
      "alias": "gxp-forms",
      "description": "Username/password then mandatory TOTP",
      "providerId": "basic-flow",
      "topLevel": false,
      "builtIn": false,
      "authenticationExecutions": [
        { "authenticator": "auth-username-password-form", "requirement": "REQUIRED", "priority": 10 },
        { "authenticator": "auth-otp-form",               "requirement": "REQUIRED", "priority": 20 }
      ]
    }
  ],

  "browserFlow": "gxp-browser-mfa",

  "passwordPolicy": "length(12) and upperCase(1) and lowerCase(1) and digits(1) and specialChars(1) and notUsername and passwordHistory(5)",

  "smtpServer": {
    "host": "localhost",
    "port": "25",
    "from": "noreply@{gxp_domain}",
    "fromDisplayName": "GXP Platform"
  }
}
